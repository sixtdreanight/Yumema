{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "outDir": "dist/main"
  },
  "include": [
    "src/main/**/*.ts",
    "src/core/**/*.ts",
    "src/adapters/**/*.ts",
    "src/cli/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
